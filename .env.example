CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token
REPO_PATH=/path/to/your/repo

# Git identity used for commits made inside the container
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=you@example.com

# Use CLAUDE_PROMPT para instruções em linguagem natural ao Claude
CLAUDE_PROMPT=Analise o código e corrija os bugs encontrados

# Use CLAUDE_COMMAND para executar um comando shell diretamente (bypassa o Claude)
# CLAUDE_COMMAND=./scripts/run.sh

# Mount the host ~/.claude directory to reuse Claude Code config/memory (optional)
# Set to the absolute path of the directory you want to mount, or leave as default
CLAUDE_CONFIG_DIR=${HOME}/.claude
